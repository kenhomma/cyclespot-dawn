{{ 'section-about-company.css' | asset_url | stylesheet_tag }}

<section class="about-company">
  <div class="page-width">
    {%- comment -%} ===== ヘッダー ===== {%- endcomment -%}
    <div class="about-company__intro cs-fade-in">
      {%- if section.settings.kicker != blank -%}
        <p class="about-company__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h1 class="about-company__title">{{ section.settings.title | default: '企業・ブランド情報' }}</h1>
      {%- if section.settings.lead != blank -%}
        <p class="about-company__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ===== セクションブロック ===== {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'vision' -%}
          <div class="about-company__section cs-fade-in" {{ block.shopify_attributes }}>
            <h2 class="about-company__section-title">{{ block.settings.heading | default: 'ビジョン' }}</h2>
            <div class="about-company__vision-grid cs-fade-in cs-fade-in--stagger">
              {%- if block.settings.purpose != blank -%}
                <div class="about-company__vision-item">
                  <h3 class="about-company__vision-label">Purpose</h3>
                  <p class="about-company__vision-text">{{ block.settings.purpose }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.mission != blank -%}
                <div class="about-company__vision-item">
                  <h3 class="about-company__vision-label">Mission</h3>
                  <p class="about-company__vision-text">{{ block.settings.mission }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.vision != blank -%}
                <div class="about-company__vision-item">
                  <h3 class="about-company__vision-label">Vision</h3>
                  <p class="about-company__vision-text">{{ block.settings.vision }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.values != blank -%}
                <div class="about-company__vision-item">
                  <h3 class="about-company__vision-label">Values</h3>
                  <p class="about-company__vision-text">{{ block.settings.values }}</p>
                </div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'overview' -%}
          <div class="about-company__section cs-fade-in" {{ block.shopify_attributes }}>
            <h2 class="about-company__section-title">{{ block.settings.heading | default: '会社概要' }}</h2>
            <table class="about-company__table">
              {%- if block.settings.company_name != blank -%}
                <tr><th>会社名</th><td>{{ block.settings.company_name }}</td></tr>
              {%- endif -%}
              {%- if block.settings.representative != blank -%}
                <tr><th>代表者</th><td>{{ block.settings.representative }}</td></tr>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <tr><th>所在地</th><td>{{ block.settings.address }}</td></tr>
              {%- endif -%}
              {%- if block.settings.established != blank -%}
                <tr><th>設立</th><td>{{ block.settings.established }}</td></tr>
              {%- endif -%}
              {%- if block.settings.business != blank -%}
                <tr><th>事業内容</th><td>{{ block.settings.business }}</td></tr>
              {%- endif -%}
              {%- if block.settings.stores_count != blank -%}
                <tr><th>店舗数</th><td>{{ block.settings.stores_count }}</td></tr>
              {%- endif -%}
            </table>
          </div>

        {%- when 'richtext' -%}
          <div class="about-company__section cs-fade-in" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="about-company__section-title">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="about-company__richtext rte">
              {{ block.settings.body }}
            </div>
          </div>

        {%- when 'cta_banner' -%}
          <div class="about-company__cta cs-fade-in" {{ block.shopify_attributes }}>
            <h2 class="about-company__cta-heading">{{ block.settings.heading }}</h2>
            {%- if block.settings.text != blank -%}
              <p class="about-company__cta-text">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="cs-btn cs-btn--secondary">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

