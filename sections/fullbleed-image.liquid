{{ 'section-fullbleed-image.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #fullbleed-{{ section.id }} {
    --fb-height-desktop: {{ section.settings.height_desktop }}vh;
    --fb-height-mobile: {{ section.settings.height_mobile }}vh;
    --fb-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --fb-focal: {{ section.settings.focal_point }};
  }
{%- endstyle -%}

<section class="fullbleed-image" id="fullbleed-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <div class="fullbleed-image__media">
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '375, 750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          class: 'fullbleed-image__img'
      }}
    </div>
  {%- else -%}
    <div class="fullbleed-image__media" style="background: linear-gradient(135deg, var(--cs-color-warm-bg-alt) 0%, var(--cs-color-warm-bg) 100%);"></div>
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="fullbleed-image__overlay"></div>
  {%- endif -%}

  {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.button_label != blank -%}
    <div class="fullbleed-image__content">
      <div class="fullbleed-image__text cs-fade-in">
        {%- if section.settings.heading != blank -%}
          <h2 class="fullbleed-image__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="fullbleed-image__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="cs-btn cs-btn--primary" style="color:#fff;border-color:#fff;background:transparent;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "フルブリード画像（CS）",
  "tag": "section",
  "class": "section--fullbleed",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "vh",
      "label": "高さ（デスクトップ）",
      "default": 50
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 25,
      "max": 70,
      "step": 5,
      "unit": "vh",
      "label": "高さ（モバイル）",
      "default": 40
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "フォーカルポイント",
      "options": [
        { "value": "center center", "label": "中央" },
        { "value": "center top", "label": "上" },
        { "value": "center bottom", "label": "下" },
        { "value": "left center", "label": "左" },
        { "value": "right center", "label": "右" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "オーバーレイ濃度",
      "default": 20
    },
    {
      "type": "header",
      "content": "テキスト（任意）"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "サブテキスト"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "presets": [
    {
      "name": "フルブリード画像（CS）"
    }
  ]
}
{% endschema %}
