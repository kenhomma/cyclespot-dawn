{{ 'section-store-list.css' | asset_url | stylesheet_tag }}

{%- comment -%} Leaflet CSS + JS (free, no API key required) {%- endcomment -%}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" crossorigin="">
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" crossorigin="">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js" crossorigin=""></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  <div class="cs-fade-in">
    <h1 class="store-list__title h1">{{ section.settings.title | default: '店舗一覧' }}</h1>
    {% if section.settings.description != blank %}
      <p class="store-list__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  {%- comment -%} ===== 全店舗マップ ===== {%- endcomment -%}
  <div class="store-list__map" id="store-map"></div>

  {%- comment -%} ===== 検索タブ ===== {%- endcomment -%}
  <div class="store-list__search-tabs">
    <button class="store-list__tab active" data-tab="nearby">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>
      現在地から探す
    </button>
    <button class="store-list__tab" data-tab="area">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      エリアから探す
    </button>
    <button class="store-list__tab" data-tab="search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      検索する
    </button>
  </div>

  {%- comment -%} ===== 1. 現在地から探す ===== {%- endcomment -%}
  <div class="store-list__panel active" data-panel="nearby">
    <button class="store-list__nearby-btn button" id="btn-nearby">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>
      現在地を取得して近くの店舗を表示
    </button>
    <p class="store-list__nearby-status" id="nearby-status"></p>
  </div>

  {%- comment -%} ===== 2. エリアから探す ===== {%- endcomment -%}
  <div class="store-list__panel" data-panel="area">
    <div class="store-list__area-selects">
      <select class="store-list__select" id="select-pref">
        <option value="">都道府県を選択</option>
      </select>
      <select class="store-list__select" id="select-city" disabled>
        <option value="">市区町村を選択</option>
      </select>
    </div>
  </div>

  {%- comment -%} ===== 3. 検索する ===== {%- endcomment -%}
  <div class="store-list__panel" data-panel="search">
    <div class="store-list__search-box">
      <input type="text" class="store-list__search-input" id="search-input"
             placeholder="店舗名・住所・駅名で検索">
      <button class="store-list__search-btn" id="btn-search">検索</button>
    </div>
  </div>

  {%- comment -%} ===== 店舗タイプ切替 ===== {%- endcomment -%}
  <div class="store-list__type-filters" data-type-filters>
    <button class="store-list__type-btn active" data-type="all">すべて</button>
    <button class="store-list__type-btn" data-type="cyclespot">サイクルスポット</button>
    <button class="store-list__type-btn" data-type="le_cyc">ル・サイク</button>
  </div>

  {%- comment -%} ===== 店舗カード一覧 ===== {%- endcomment -%}
  {%- assign stores = shop.metaobjects.store.values -%}
  <div class="store-list__grid" data-store-grid>
    {%- for store in stores -%}
      {%- assign address_full = store.address | default: '' -%}

      {%- comment -%} 都道府県を抽出 {%- endcomment -%}
      {%- assign prefecture = '' -%}
      {%- if address_full contains '東京都' -%}{%- assign prefecture = '東京都' -%}
      {%- elsif address_full contains '神奈川県' -%}{%- assign prefecture = '神奈川県' -%}
      {%- elsif address_full contains '埼玉県' -%}{%- assign prefecture = '埼玉県' -%}
      {%- elsif address_full contains '千葉県' -%}{%- assign prefecture = '千葉県' -%}
      {%- elsif address_full contains '静岡県' -%}{%- assign prefecture = '静岡県' -%}
      {%- elsif address_full contains '茨城県' -%}{%- assign prefecture = '茨城県' -%}
      {%- endif -%}

      {%- assign store_url = store.system.url -%}
      {%- if store_url == blank -%}{%- assign store_url = '/pages/stores/' | append: store.handle -%}{%- endif -%}
      <a href="{{ store_url }}"
         class="store-list__card"
         data-prefecture="{{ prefecture }}"
         data-store-type="{{ store.type }}"
         data-lat="{{ store.latitude }}"
         data-lng="{{ store.longitude }}"
         data-name="{{ store.name }}"
         data-address="{{ address_full }}"
         data-distance="">
        <div class="store-list__card-inner">
          {%- comment -%} 店舗画像 {%- endcomment -%}
          <div class="store-list__card-image">
            {%- if store.image != blank -%}
              <img src="{{ store.image | image_url: width: 400 }}" alt="{{ store.name }}" loading="lazy" width="400" height="267">
            {%- else -%}
              <div class="store-list__card-image-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
            {%- endif -%}
          </div>
          <div class="store-list__card-body">
            <div class="store-list__card-header">
              {%- if store.type == 'le_cyc' -%}
                <span class="store-list__badge store-list__badge--lecyc">ル・サイク</span>
              {%- else -%}
                <span class="store-list__badge store-list__badge--cyclespot">サイクルスポット</span>
              {%- endif -%}
              <span class="store-list__distance" data-distance-label></span>
            </div>
            <h3 class="store-list__card-name">{{ store.name }}</h3>
            <div class="store-list__card-info">
              <p class="store-list__card-address">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {{ address_full | remove: '〒' | truncate: 40 }}
              </p>
              <p class="store-list__card-hours">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {{ store.opening_hours }}
              </p>
              <p class="store-list__card-phone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {{ store.phone }}
              </p>
            </div>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>

  <p class="store-list__count" data-store-count>
    {{ stores.size }}店舗
  </p>
</div>

{%- comment -%} ===== 店舗データ JSON（JS用） ===== {%- endcomment -%}
<script id="store-data" type="application/json">
  [
    {%- for store in stores -%}
      {%- assign s_url = store.system.url -%}
      {%- if s_url == blank -%}{%- assign s_url = '/pages/stores/' | append: store.handle -%}{%- endif -%}
      {
        "slug": {{ store.slug | json }},
        "name": {{ store.name | json }},
        "lat": {{ store.latitude | default: '0' | json }},
        "lng": {{ store.longitude | default: '0' | json }},
        "type": {{ store.type | json }},
        "address": {{ store.address | default: '' | json }},
        "phone": {{ store.phone | default: '' | json }},
        "hours": {{ store.opening_hours | default: '' | json }},
        "url": {{ s_url | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  /* ========== Data ========== */
  var storeData = JSON.parse(document.getElementById('store-data').textContent);
  var cards = document.querySelectorAll('.store-list__card');
  var countEl = document.querySelector('[data-store-count]');
  var currentType = 'all';
  var currentFilter = { mode: 'all', prefecture: '', city: '', query: '' };

  /* ========== Leaflet Map ========== */
  var map = L.map('store-map', {
    center: [35.68, 139.76],
    zoom: 10,
    scrollWheelZoom: false
  });

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map);

  /* Enable scroll zoom after first click on map */
  map.once('click', function() { map.scrollWheelZoom.enable(); });

  /* Marker cluster group */
  var markers = L.markerClusterGroup({
    maxClusterRadius: 40,
    spiderfyOnMaxZoom: true,
    showCoverageOnHover: false
  });

  /* Custom circle marker icons */
  function storeIcon(type) {
    var color = type === 'le_cyc' ? '#2d4a7d' : '#2d7d2d';
    return L.divIcon({
      className: 'store-list__marker',
      html: '<div style="width:16px;height:16px;border-radius:50%;background:' + color + ';border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>',
      iconSize: [16, 16],
      iconAnchor: [8, 8],
      popupAnchor: [0, -10]
    });
  }

  /* Store markers by slug for later filtering */
  var markerMap = {};
  storeData.forEach(function(s) {
    var lat = parseFloat(s.lat);
    var lng = parseFloat(s.lng);
    if (!lat || !lng) return;

    var marker = L.marker([lat, lng], { icon: storeIcon(s.type) });
    var addr = s.address.replace(/〒\S+\s*/, '');
    marker.bindPopup(
      '<div style="font-size:14px;line-height:1.5;min-width:180px">' +
      '<strong>' + s.name + '</strong><br>' +
      addr + '<br>' +
      s.phone + '<br>' +
      '<a href="' + s.url + '" style="color:#2d7d2d;font-weight:600">詳細を見る →</a>' +
      '</div>'
    );
    marker.storeData = s;
    markers.addLayer(marker);
    markerMap[s.slug] = marker;
  });
  map.addLayer(markers);

  /* Fit map to show all markers */
  if (markers.getLayers().length > 0) {
    map.fitBounds(markers.getBounds().pad(0.05));
  }

  /* User location marker */
  var userMarker = null;

  /* ========== Tabs ========== */
  var tabs = document.querySelectorAll('.store-list__tab');
  var panels = document.querySelectorAll('.store-list__panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('active'); });
      panels.forEach(function(p) { p.classList.remove('active'); });
      tab.classList.add('active');
      var panel = document.querySelector('[data-panel="' + tab.dataset.tab + '"]');
      if (panel) panel.classList.add('active');
    });
  });

  /* ========== Type filters ========== */
  document.querySelectorAll('[data-type]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('[data-type]').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentType = btn.dataset.type;
      applyAllFilters();
    });
  });

  /* ========== Apply all filters ========== */
  function applyAllFilters() {
    var visible = 0;
    var visibleSlugs = [];
    cards.forEach(function(card) {
      var show = true;
      var type = card.dataset.storeType;
      if (currentType !== 'all' && type !== currentType) show = false;

      if (show && currentFilter.mode === 'prefecture' && currentFilter.prefecture) {
        if (card.dataset.prefecture !== currentFilter.prefecture) show = false;
      }
      if (show && currentFilter.mode === 'city' && currentFilter.city) {
        if (!card.dataset.address.includes(currentFilter.city)) show = false;
      }
      if (show && currentFilter.mode === 'search' && currentFilter.query) {
        var q = currentFilter.query.toLowerCase();
        var name = (card.dataset.name || '').toLowerCase();
        var addr = (card.dataset.address || '').toLowerCase();
        if (!name.includes(q) && !addr.includes(q)) show = false;
      }

      card.style.display = show ? '' : 'none';
      if (show) {
        visible++;
        /* Find slug from storeData by matching name */
        var cardName = card.dataset.name;
        storeData.forEach(function(s) {
          if (s.name === cardName) visibleSlugs.push(s.slug);
        });
      }
    });
    if (countEl) countEl.textContent = visible + '店舗';

    /* Update map markers to match visible stores */
    updateMapMarkers(visibleSlugs);
  }

  function updateMapMarkers(visibleSlugs) {
    markers.clearLayers();
    var bounds = [];
    storeData.forEach(function(s) {
      if (visibleSlugs.length > 0 && visibleSlugs.indexOf(s.slug) === -1) return;
      var m = markerMap[s.slug];
      if (m) {
        markers.addLayer(m);
        bounds.push(m.getLatLng());
      }
    });
    if (bounds.length > 0) {
      map.fitBounds(L.latLngBounds(bounds).pad(0.05));
    }
  }

  /* ========== 1. Nearby ========== */
  document.getElementById('btn-nearby').addEventListener('click', function() {
    var status = document.getElementById('nearby-status');
    status.textContent = '位置情報を取得中...';
    if (!navigator.geolocation) {
      status.textContent = 'お使いのブラウザでは位置情報が利用できません。';
      return;
    }
    navigator.geolocation.getCurrentPosition(function(pos) {
      var userLat = pos.coords.latitude;
      var userLng = pos.coords.longitude;
      status.textContent = '近い順に並べ替えました';

      /* Show user location on map */
      if (userMarker) map.removeLayer(userMarker);
      userMarker = L.marker([userLat, userLng], {
        icon: L.divIcon({
          className: 'store-list__user-marker',
          html: '<div style="width:20px;height:20px;border-radius:50%;background:#3b82f6;border:3px solid #fff;box-shadow:0 0 0 3px rgba(59,130,246,0.3),0 2px 6px rgba(0,0,0,0.3);"></div>',
          iconSize: [20, 20],
          iconAnchor: [10, 10]
        }),
        zIndexOffset: 1000
      }).addTo(map);
      userMarker.bindPopup('<strong>現在地</strong>').openPopup();

      /* Calculate distances */
      cards.forEach(function(card) {
        var lat = parseFloat(card.dataset.lat) || 0;
        var lng = parseFloat(card.dataset.lng) || 0;
        if (lat && lng) {
          var d = haversine(userLat, userLng, lat, lng);
          card.dataset.distance = d.toFixed(1);
          var label = card.querySelector('[data-distance-label]');
          if (label) label.textContent = d < 1 ? (d * 1000).toFixed(0) + 'm' : d.toFixed(1) + 'km';
        }
      });

      /* Sort by distance */
      var grid = document.querySelector('[data-store-grid]');
      var sorted = Array.from(cards).sort(function(a, b) {
        return (parseFloat(a.dataset.distance) || 9999) - (parseFloat(b.dataset.distance) || 9999);
      });
      sorted.forEach(function(card) { grid.appendChild(card); });

      /* Center map on user location with nearby stores visible */
      map.setView([userLat, userLng], 13);

      currentFilter = { mode: 'all', prefecture: '', city: '', query: '' };
      applyAllFilters();
    }, function(err) {
      status.textContent = '位置情報の取得に失敗しました。ブラウザの設定をご確認ください。';
    }, { enableHighAccuracy: true, timeout: 10000 });
  });

  function haversine(lat1, lon1, lat2, lon2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLon = (lon2 - lon1) * Math.PI / 180;
    var a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon/2) * Math.sin(dLon/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  }

  /* ========== 2. Area selects ========== */
  var prefSelect = document.getElementById('select-pref');
  var citySelect = document.getElementById('select-city');

  var areaMap = {};
  storeData.forEach(function(s) {
    var addr = s.address;
    var pref = '';
    ['東京都','神奈川県','埼玉県','千葉県','静岡県','茨城県'].forEach(function(p) {
      if (addr.includes(p)) pref = p;
    });
    if (!pref) return;
    if (!areaMap[pref]) areaMap[pref] = {};
    var afterPref = addr.split(pref)[1] || '';
    var cityMatch = afterPref.match(/^(.+?[市区町村])/);
    if (cityMatch) areaMap[pref][cityMatch[1]] = true;
  });

  Object.keys(areaMap).sort().forEach(function(pref) {
    var opt = document.createElement('option');
    opt.value = pref; opt.textContent = pref;
    prefSelect.appendChild(opt);
  });

  prefSelect.addEventListener('change', function() {
    citySelect.innerHTML = '<option value="">市区町村を選択</option>';
    var pref = prefSelect.value;
    if (pref && areaMap[pref]) {
      citySelect.disabled = false;
      Object.keys(areaMap[pref]).sort().forEach(function(city) {
        var opt = document.createElement('option');
        opt.value = city; opt.textContent = city;
        citySelect.appendChild(opt);
      });
    } else {
      citySelect.disabled = true;
    }
    currentFilter = { mode: pref ? 'prefecture' : 'all', prefecture: pref, city: '', query: '' };
    applyAllFilters();
  });

  citySelect.addEventListener('change', function() {
    var city = citySelect.value;
    currentFilter.mode = city ? 'city' : 'prefecture';
    currentFilter.city = city;
    applyAllFilters();
  });

  /* ========== 3. Text search ========== */
  var searchInput = document.getElementById('search-input');
  function doSearch() {
    var q = searchInput.value.trim();
    currentFilter = { mode: q ? 'search' : 'all', prefecture: '', city: '', query: q };
    applyAllFilters();
  }
  document.getElementById('btn-search').addEventListener('click', doSearch);
  searchInput.addEventListener('keyup', function(e) {
    if (e.key === 'Enter') doSearch();
    if (searchInput.value.length >= 2 || searchInput.value.length === 0) doSearch();
  });
});
</script>

{% schema %}
{
  "name": "店舗一覧",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "タイトル",
      "default": "店舗一覧"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "説明文",
      "default": "お近くの店舗をお探しください。修理・メンテナンスもお気軽にご相談ください。"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "店舗一覧"
    }
  ]
}
{% endschema %}
