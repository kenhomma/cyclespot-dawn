{{ 'section-stories-preview.css' | asset_url | stylesheet_tag }}

{%- assign stories_blog = blogs[section.settings.blog] -%}

<section class="stories-preview">
  <div class="page-width">
    <div class="stories-preview__layout">
      {%- comment -%} 左：イメージ {%- endcomment -%}
      <div class="stories-preview__image cs-fade-in">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1000',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'stories-preview__img'
          }}
        {%- else -%}
          <div class="stories-preview__placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} 右：テキスト + 動的記事カード {%- endcomment -%}
      <div class="stories-preview__content cs-fade-in">
        {%- if section.settings.kicker != blank -%}
          <p class="stories-preview__kicker">{{ section.settings.kicker }}</p>
        {%- endif -%}
        <h2 class="stories-preview__heading">{{ section.settings.heading | default: 'CYCLESPOT STORIES' }}</h2>
        <div class="stories-preview__text">
          {{ section.settings.text }}
        </div>

        {%- comment -%} 動的記事カード（ブログから取得） {%- endcomment -%}
        {%- if stories_blog != blank and stories_blog.articles_count > 0 -%}
          <div class="stories-preview__cards">
            {%- for article in stories_blog.articles limit: section.settings.articles_to_show -%}
              <a href="{{ article.url }}" class="stories-preview__card">
                {%- if article.image -%}
                  <div class="stories-preview__card-thumb">
                    {{ article.image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'stories-preview__card-thumb-img' }}
                  </div>
                {%- endif -%}
                <div class="stories-preview__card-info">
                  <time class="stories-preview__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                    {{ article.published_at | date: '%Y.%m.%d' }}
                  </time>
                  <span class="stories-preview__card-title">{{ article.title }}</span>
                </div>
                <span class="stories-preview__card-arrow">&rarr;</span>
              </a>
            {%- endfor -%}
          </div>

        {%- elsif section.blocks.size > 0 -%}
          {%- comment -%} フォールバック：静的リンクブロック {%- endcomment -%}
          <div class="stories-preview__cards">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.url }}" class="stories-preview__card" {{ block.shopify_attributes }}>
                <div class="stories-preview__card-info">
                  <span class="stories-preview__card-title">{{ block.settings.title }}</span>
                </div>
                <span class="stories-preview__card-arrow">&rarr;</span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="cs-btn--text" style="margin-top: 2rem; display: inline-block;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ストーリー紹介（CS）",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "キッカー",
      "default": "STORIES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "CYCLESPOT STORIES"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "本文",
      "default": "<p>「自転車屋は関所にならなければいけない」「修理は命に関わる」――サイクルスポットのスタッフが語る、自転車と街と人のストーリー。</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "ブログ（記事を自動取得）"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "表示する記事数"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル",
      "default": "すべてのストーリーを読む"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "blocks": [
    {
      "type": "story_link",
      "name": "ストーリーリンク（手動）",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "森SVインタビュー"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ストーリー紹介（CS）",
      "blocks": []
    }
  ]
}
{% endschema %}
