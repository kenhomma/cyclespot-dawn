{{ 'section-stories-preview.css' | asset_url | stylesheet_tag }}

<section class="stories-preview">
  <div class="page-width">
    <div class="stories-preview__layout">
      {%- comment -%} 左：イメージ {%- endcomment -%}
      <div class="stories-preview__image cs-fade-in">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1000',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'stories-preview__img'
          }}
        {%- else -%}
          <div class="stories-preview__placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} 右：テキスト {%- endcomment -%}
      <div class="stories-preview__content cs-fade-in">
        {%- if section.settings.kicker != blank -%}
          <p class="stories-preview__kicker">{{ section.settings.kicker }}</p>
        {%- endif -%}
        <h2 class="stories-preview__heading">{{ section.settings.heading | default: 'CYCLESPOT STORIES' }}</h2>
        <div class="stories-preview__text">
          {{ section.settings.text }}
        </div>

        {%- comment -%} ストーリーカード {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="stories-preview__cards">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.url }}" class="stories-preview__card" {{ block.shopify_attributes }}>
                <span class="stories-preview__card-title">{{ block.settings.title }}</span>
                <span class="stories-preview__card-arrow">&rarr;</span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="cs-btn--text" style="margin-top: 2rem; display: inline-block;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ストーリー紹介（CS）",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "キッカー",
      "default": "STORIES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "CYCLESPOT STORIES"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "本文",
      "default": "<p>「自転車屋は関所にならなければいけない」「修理は命に関わる」――サイクルスポットのスタッフが語る、自転車と街と人のストーリー。</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル",
      "default": "すべてのストーリーを読む"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "blocks": [
    {
      "type": "story_link",
      "name": "ストーリーリンク",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "森SVインタビュー"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ストーリー紹介（CS）",
      "blocks": [
        {
          "type": "story_link",
          "settings": {
            "title": "「自転車屋は関所にならなければいけない」— 森SV"
          }
        },
        {
          "type": "story_link",
          "settings": {
            "title": "「断らない」を貫く武蔵小山店の日常"
          }
        },
        {
          "type": "story_link",
          "settings": {
            "title": "創業者 高瀬が語る、自転車屋のはじまり"
          }
        }
      ]
    }
  ]
}
{% endschema %}
