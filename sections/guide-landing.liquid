{{ 'section-guide-landing.css' | asset_url | stylesheet_tag }}

<section class="guide-landing">
  <div class="page-width">
    {%- comment -%} ===== イントロ ===== {%- endcomment -%}
    <div class="guide-landing__intro cs-fade-in">
      {%- if section.settings.kicker != blank -%}
        <p class="guide-landing__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h1 class="guide-landing__title">{{ section.settings.title | default: '選び方・安心サポート' }}</h1>
      {%- if section.settings.lead != blank -%}
        <p class="guide-landing__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ===== ガイドカード ===== {%- endcomment -%}
    {%- assign guide_blocks = section.blocks | where: 'type', 'guide_card' -%}
    {%- if guide_blocks.size > 0 -%}
      <div class="guide-landing__grid cs-fade-in cs-fade-in--stagger">
        {%- for block in guide_blocks -%}
          <div class="guide-landing__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="guide-landing__card-image">
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 450, 600',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    class: 'guide-landing__card-img'
                }}
              </div>
            {%- else -%}
              <div class="guide-landing__card-image guide-landing__card-image--placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.3"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
              </div>
            {%- endif -%}
            <h3 class="guide-landing__card-title">{{ block.settings.title }}</h3>
            <p class="guide-landing__card-text">{{ block.settings.text }}</p>
            {%- if block.settings.link_label != blank -%}
              <a href="{{ block.settings.link }}" class="cs-btn--text">
                {{ block.settings.link_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ===== 安心サポートポリシー ===== {%- endcomment -%}
    {%- assign policy_blocks = section.blocks | where: 'type', 'policy' -%}
    {%- if policy_blocks.size > 0 -%}
      <div class="guide-landing__policy-section cs-fade-in">
        <h2 class="about-company__section-title">{{ section.settings.policy_heading | default: '安心サポートポリシー' }}</h2>
        <div class="guide-landing__policies">
          {%- for block in policy_blocks -%}
            <div class="guide-landing__policy" {{ block.shopify_attributes }}>
              <h3 class="guide-landing__policy-title">{{ block.settings.title }}</h3>
              <p class="guide-landing__policy-text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ===== FAQ ===== {%- endcomment -%}
    {%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
    {%- if faq_blocks.size > 0 -%}
      <div class="guide-landing__faq-section cs-fade-in">
        <h2 class="about-company__section-title">{{ section.settings.faq_heading | default: 'よくある質問' }}</h2>
        <div class="guide-landing__faq">
          {%- for block in faq_blocks -%}
            <details class="guide-landing__faq-item" {{ block.shopify_attributes }}>
              <summary class="guide-landing__faq-question">{{ block.settings.question }}</summary>
              <div class="guide-landing__faq-answer rte">{{ block.settings.answer }}</div>
            </details>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

