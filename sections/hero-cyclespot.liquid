{{ 'section-hero-cyclespot.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .hero-cs {
    --hero-height: {{ section.settings.hero_height_mobile }}vh;
    --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
  @media screen and (min-width: 750px) {
    .hero-cs {
      --hero-height: {{ section.settings.hero_height_desktop }}vh;
    }
  }
{%- endstyle -%}

<section class="hero-cs" id="hero-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <div class="hero-cs__media">
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          widths: '375, 750, 1100, 1500, 1780, 2000, 2400',
          sizes: '100vw',
          class: 'hero-cs__image'
      }}
      <div class="hero-cs__overlay"></div>
    </div>
  {%- else -%}
    <div class="hero-cs__media hero-cs__media--placeholder">
      <div class="hero-cs__overlay"></div>
    </div>
  {%- endif -%}

  <div class="hero-cs__content page-width">
    <div class="hero-cs__text cs-fade-in">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'kicker' -%}
            <p class="hero-cs__kicker" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </p>
          {%- when 'heading' -%}
            <h1 class="hero-cs__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h1>
          {%- when 'subheading' -%}
            <p class="hero-cs__subheading" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </p>
          {%- when 'buttons' -%}
            <div class="hero-cs__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a href="{{ block.settings.button_link_1 }}" class="cs-btn cs-btn--primary">
                  {{ block.settings.button_label_1 }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 }}" class="cs-btn cs-btn--secondary" style="color:#fff;border-color:#fff;">
                  {{ block.settings.button_label_2 }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ヒーロー（CS）",
  "tag": "section",
  "class": "section--hero-cs",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "背景画像"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "高さ（デスクトップ）",
      "default": 85
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "高さ（モバイル）",
      "default": 70
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "オーバーレイ濃度",
      "default": 25
    },
    {
      "type": "select",
      "id": "text_position",
      "options": [
        { "value": "center", "label": "中央" },
        { "value": "left", "label": "左寄せ" },
        { "value": "bottom-left", "label": "左下" }
      ],
      "default": "center",
      "label": "テキスト位置"
    }
  ],
  "blocks": [
    {
      "type": "kicker",
      "name": "キッカーテキスト",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト",
          "default": "CYCLESPOT"
        }
      ]
    },
    {
      "type": "heading",
      "name": "見出し",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "見出し",
          "default": "断らない街の自転車屋が、\nあなたの暮らしを支える。"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "サブコピー",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "テキスト",
          "default": "オンラインで選んで、近くの店舗で受け取り。\n人の技術と提案力で、一台一台を仕上げます。"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "ボタン",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "ボタン1ラベル",
          "default": "自転車を探す"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "ボタン1リンク"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "ボタン2ラベル",
          "default": "お近くの店舗を探す"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "ボタン2リンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ヒーロー（CS）",
      "blocks": [
        { "type": "kicker" },
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
