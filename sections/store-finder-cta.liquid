{{ 'section-store-finder-cta.css' | asset_url | stylesheet_tag }}

<section class="store-cta-cs">
  <div class="store-cta-cs__inner">
    {%- if section.settings.image != blank -%}
      <div class="store-cta-cs__bg">
        {{
          section.settings.image
          | image_url: width: 2000
          | image_tag:
            loading: 'lazy',
            widths: '375, 750, 1100, 1500, 2000',
            sizes: '100vw',
            class: 'store-cta-cs__bg-img'
        }}
        <div class="store-cta-cs__overlay"></div>
      </div>
    {%- else -%}
      <div class="store-cta-cs__bg store-cta-cs__bg--gradient">
        <div class="store-cta-cs__overlay"></div>
      </div>
    {%- endif -%}

    <div class="store-cta-cs__content page-width cs-fade-in">
      {%- if section.settings.kicker != blank -%}
        <p class="store-cta-cs__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h2 class="store-cta-cs__heading">{{ section.settings.heading | default: 'お近くの店舗を探す' }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="store-cta-cs__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="cs-btn cs-btn--primary" style="background:#fff;color:var(--cs-color-text);border-color:#fff;">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "店舗CTA（CS）",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "キッカー",
      "default": "STORES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "お近くの店舗を探す"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "説明文",
      "default": "首都圏100店舗以上。パンク修理も、ちょっとした相談も、お気軽にお越しください。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル",
      "default": "店舗一覧を見る"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "背景画像"
    }
  ],
  "presets": [
    {
      "name": "店舗CTA（CS）"
    }
  ]
}
{% endschema %}
