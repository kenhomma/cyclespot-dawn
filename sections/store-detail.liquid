{{ 'section-store-detail.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- comment -%}
  店舗詳細ページ
  metaobject の handle を URL パラメータまたはページのメタフィールドから取得。
  現段階では page.metafields.custom.store_handle を参照する設計。
  将来的に metaobject テンプレートに移行可能。
{%- endcomment -%}

{%- assign store_handle = page.metafields.custom.store_handle.value -%}
{%- if store_handle == blank -%}
  {%- comment -%} フォールバック: ページハンドルから store- を除去して検索 {%- endcomment -%}
  {%- assign page_handle = page.handle | remove: 'store-' -%}
  {%- assign store_handle = page_handle -%}
{%- endif -%}

{%- assign store = shop.metaobjects.store[store_handle] -%}

{%- if store == blank -%}
  <div class="page-width section-{{ section.id }}-padding">
    <p>店舗情報が見つかりませんでした。</p>
    <a href="/pages/stores" class="button">店舗一覧に戻る</a>
  </div>
{%- else -%}

<div class="page-width section-{{ section.id }}-padding">

  {%- comment -%} ===== 1. ヘッダーエリア ===== {%- endcomment -%}
  <div class="store-detail__header cs-fade-in">
    <div class="store-detail__header-top">
      {%- if store.type == 'le_cyc' -%}
        <span class="store-detail__badge store-detail__badge--lecyc">ル・サイク</span>
      {%- else -%}
        <span class="store-detail__badge store-detail__badge--cyclespot">サイクルスポット</span>
      {%- endif -%}

      {%- comment -%} 営業ステータス — 静的表示（将来は JS で当日判定） {%- endcomment -%}
      {%- if store.regular_holiday == '無休' -%}
        <span class="store-detail__status store-detail__status--open">年中無休</span>
      {%- endif -%}
    </div>
    <h1 class="store-detail__name h1">{{ store.name }}</h1>
  </div>

  {%- comment -%} ===== 2. 基本情報 + アクセス ===== {%- endcomment -%}
  <div class="store-detail__info-grid cs-fade-in">
    <div class="store-detail__info-main">
      <table class="store-detail__info-table">
        <tr>
          <th>住所</th>
          <td>{{ store.address }}</td>
        </tr>
        <tr>
          <th>電話番号</th>
          <td><a href="tel:{{ store.phone | remove: '-' }}">{{ store.phone }}</a></td>
        </tr>
        <tr>
          <th>営業時間</th>
          <td>{{ store.opening_hours }}</td>
        </tr>
        <tr>
          <th>定休日</th>
          <td>{{ store.regular_holiday | default: '無休' }}</td>
        </tr>
      </table>

      {%- comment -%} Google Maps リンク {%- endcomment -%}
      {%- if store.gmb_url != blank -%}
        <a href="{{ store.gmb_url }}" target="_blank" rel="noopener" class="store-detail__map-link button button--secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Google マップで見る
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} 地図埋め込み {%- endcomment -%}
    <div class="store-detail__map">
      {%- if store.latitude != blank and store.longitude != blank -%}
        <iframe
          src="https://maps.google.com/maps?q={{ store.latitude }},{{ store.longitude }}&z=16&output=embed"
          width="100%"
          height="300"
          style="border:0; border-radius: 8px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ===== 2.5 店舗紹介 ===== {%- endcomment -%}
  {%- if store.description != blank -%}
  <div class="store-detail__section store-detail__about cs-fade-in">
    <h2 class="store-detail__section-title h2">店舗紹介</h2>
    <div class="store-detail__about-content">
      {%- if store.image != blank -%}
        <div class="store-detail__about-image">
          <img
            src="{{ store.image | image_url: width: 600 }}"
            alt="{{ store.name }}"
            width="600"
            height="400"
            loading="lazy"
            style="border-radius: 8px; width: 100%; height: auto; object-fit: cover;"
          >
        </div>
      {%- endif -%}
      <div class="store-detail__about-text">
        {{ store.description | newline_to_br }}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ===== 2.8 店舗在庫一覧 ===== {%- endcomment -%}
  {%- assign inv_raw = store.inventory_json.value -%}
  {%- if inv_raw and inv_raw.items.size > 0 -%}
  <div class="store-detail__section store-detail__inventory">
    <h2 class="store-detail__section-title h2">
      取扱商品
      <span class="store-detail__inventory-count">{{ inv_raw.count }}台</span>
    </h2>

    {%- if inv_raw.updated_at -%}
      <p class="store-detail__inventory-updated">
        最終更新: {{ inv_raw.updated_at | date: "%Y/%m/%d" }}
      </p>
    {%- endif -%}

    {%- comment -%} カテゴリでグループ化して表示 {%- endcomment -%}
    {%- assign categories = '' -%}
    {%- for item in inv_raw.items -%}
      {%- assign item_cat = item.category | default: 'その他' -%}
      {%- unless categories contains item_cat -%}
        {%- if categories != '' -%}{%- assign categories = categories | append: '|' -%}{%- endif -%}
        {%- assign categories = categories | append: item_cat -%}
      {%- endunless -%}
    {%- endfor -%}
    {%- assign category_list = categories | split: '|' -%}

    {%- for cat in category_list -%}
      <details class="store-detail__inventory-category"{% if forloop.first %} open{% endif %}>
        <summary class="store-detail__inventory-category-title">
          {{ cat }}
          {%- assign cat_count = 0 -%}
          {%- for item in inv_raw.items -%}
            {%- assign item_cat_check = item.category | default: 'その他' -%}
            {%- if item_cat_check == cat -%}
              {%- for v in item.variants -%}
                {%- assign cat_count = cat_count | plus: v.qty -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          <span class="store-detail__inventory-cat-count">{{ cat_count }}台</span>
        </summary>
        <div class="store-detail__inventory-grid">
          {%- for item in inv_raw.items -%}
            {%- assign item_cat_match = item.category | default: 'その他' -%}
            {%- if item_cat_match == cat -%}
              <a href="/products/{{ item.handle }}" class="store-detail__inventory-card">
                {%- if item.image_url != blank -%}
                  {%- assign inv_img_src = item.image_url -%}
                  {%- if inv_img_src contains '?' -%}
                    {%- assign inv_img_src = inv_img_src | append: '&width=240' -%}
                  {%- else -%}
                    {%- assign inv_img_src = inv_img_src | append: '?width=240' -%}
                  {%- endif -%}
                  <div class="store-detail__inventory-card-image">
                    <img
                      src="{{ inv_img_src }}"
                      alt="{{ item.title }}"
                      width="96"
                      height="96"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
                <div class="store-detail__inventory-card-body">
                  <h3 class="store-detail__inventory-card-title">{{ item.title }}</h3>
                  <span class="store-detail__inventory-card-price">{{ item.price_display }}</span>
                  <ul class="store-detail__inventory-variants">
                    {%- for v in item.variants -%}
                      <li>
                        {%- if v.color != blank -%}
                          <span class="store-detail__inventory-color">{{ v.color }}</span>
                        {%- endif -%}
                        <span class="store-detail__inventory-qty">{{ v.qty }}台</span>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </details>
    {%- endfor -%}
  </div>
  {%- endif -%}

  {%- comment -%} ===== 2.9 スタッフ紹介（ブロック） ===== {%- endcomment -%}
  {%- assign staff_blocks = section.blocks | where: 'type', 'staff' -%}
  {%- if staff_blocks.size > 0 -%}
  <div class="store-detail__section">
    <h2 class="store-detail__section-title h2">スタッフ紹介</h2>
    <div class="store-detail__staff-grid cs-fade-in cs-fade-in--stagger">
      {%- for block in staff_blocks -%}
        <div class="store-detail__staff-card" {{ block.shopify_attributes }}>
          {%- if block.settings.staff_photo != blank -%}
            <div class="store-detail__staff-photo">
              <img
                src="{{ block.settings.staff_photo | image_url: width: 200, height: 200, crop: 'center' }}"
                alt="{{ block.settings.staff_name }}"
                width="200"
                height="200"
                loading="lazy"
              >
            </div>
          {%- else -%}
            <div class="store-detail__staff-photo store-detail__staff-photo--placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
            </div>
          {%- endif -%}
          <div class="store-detail__staff-info">
            <h3 class="store-detail__staff-name">{{ block.settings.staff_name }}</h3>
            {%- if block.settings.staff_role != blank -%}
              <span class="store-detail__staff-role">{{ block.settings.staff_role }}</span>
            {%- endif -%}
            {%- if block.settings.staff_expertise != blank -%}
              <span class="store-detail__staff-expertise">得意分野: {{ block.settings.staff_expertise }}</span>
            {%- endif -%}
            {%- if block.settings.staff_comment != blank -%}
              <p class="store-detail__staff-comment">{{ block.settings.staff_comment }}</p>
            {%- endif -%}
            {%- if block.settings.staff_story_url != blank -%}
              <a href="{{ block.settings.staff_story_url }}" class="store-detail__staff-story-link">
                ストーリーを読む →
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ===== 3. 工賃表・サービス案内（ブロック） ===== {%- endcomment -%}
  {%- if section.settings.show_services -%}
  <div class="store-detail__section">
    <h2 class="store-detail__section-title h2">修理・サービス</h2>
    <div class="store-detail__services-grid cs-fade-in cs-fade-in--stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'service' -%}
          <div class="store-detail__service-card" {{ block.shopify_attributes }}>
            <h3 class="store-detail__service-name">{{ block.settings.service_name }}</h3>
            <p class="store-detail__service-price">{{ block.settings.service_price }}</p>
            {%- if block.settings.service_note != blank -%}
              <p class="store-detail__service-note">{{ block.settings.service_note }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ===== 4. FAQ（ブロック） ===== {%- endcomment -%}
  {%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
  {%- if faq_blocks.size > 0 -%}
  <div class="store-detail__section">
    <h2 class="store-detail__section-title h2">よくある質問</h2>
    <div class="store-detail__faq">
      {%- for block in faq_blocks -%}
        <details class="store-detail__faq-item" {{ block.shopify_attributes }}>
          <summary class="store-detail__faq-question">{{ block.settings.question }}</summary>
          <div class="store-detail__faq-answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ===== 5. 店舗一覧へ戻る ===== {%- endcomment -%}
  <div class="store-detail__back">
    <a href="/pages/stores" class="store-detail__back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      店舗一覧に戻る
    </a>
  </div>

</div>
{%- endif -%}

{% schema %}
{
  "name": "店舗詳細",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_services",
      "label": "修理・サービス欄を表示",
      "default": true
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "修理メニュー",
      "settings": [
        {
          "type": "text",
          "id": "service_name",
          "label": "メニュー名",
          "default": "パンク修理"
        },
        {
          "type": "text",
          "id": "service_price",
          "label": "料金",
          "default": "¥1,100〜"
        },
        {
          "type": "text",
          "id": "service_note",
          "label": "備考"
        }
      ]
    },
    {
      "type": "staff",
      "name": "スタッフ",
      "settings": [
        {
          "type": "text",
          "id": "staff_name",
          "label": "名前",
          "default": "スタッフ名"
        },
        {
          "type": "text",
          "id": "staff_role",
          "label": "役職・肩書"
        },
        {
          "type": "image_picker",
          "id": "staff_photo",
          "label": "顔写真"
        },
        {
          "type": "text",
          "id": "staff_expertise",
          "label": "得意分野"
        },
        {
          "type": "textarea",
          "id": "staff_comment",
          "label": "ひとことコメント"
        },
        {
          "type": "url",
          "id": "staff_story_url",
          "label": "ストーリーページURL"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "質問",
          "default": "他店で購入した自転車も修理できますか？"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "回答",
          "default": "<p>はい、他店でご購入の自転車も修理いたします。お気軽にお持ちください。</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "店舗詳細",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "service_name": "パンク修理",
            "service_price": "¥1,100〜"
          }
        },
        {
          "type": "service",
          "settings": {
            "service_name": "ブレーキ調整",
            "service_price": "¥550〜"
          }
        },
        {
          "type": "service",
          "settings": {
            "service_name": "チェーン交換",
            "service_price": "¥2,200〜"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "他店で購入した自転車も修理できますか？",
            "answer": "<p>はい、他店でご購入の自転車も修理いたします。お気軽にお持ちください。</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "修理の待ち時間はどのくらいですか？",
            "answer": "<p>パンク修理で約15〜30分、その他の修理は内容により異なります。混雑時はお預かりとなる場合があります。</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
