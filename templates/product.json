{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'brand-logo' %}"
          }
        },
        "title": {
          "type": "title"
        },
        "catalog_price": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'catalog-price' %}"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "ec_link": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'ec-link-button' %}"
          }
        },
        "description": {
          "type": "description"
        },
        "specs": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'product-specs' %}"
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "シェアする"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "catalog_price",
        "variant_picker",
        "ec_link",
        "description",
        "specs",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "thumbnail",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "関連する自転車",
        "heading_size": "h2",
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "adapt",
        "show_secondary_image": true,
        "show_vendor": true,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "related-products"
  ]
}
